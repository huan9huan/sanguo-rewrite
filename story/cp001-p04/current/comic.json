        "asset_key": "cp001-p04-page-01-f4",
        "aspect_ratio": "4:3",
        "crop_mode": "contain"
      },
      "text_block": {
        "title": "关羽一刀打穿阵心",
        "items": [
          {
            "id": "f4_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "程远志刚冲上来，关羽的青龙刀已横扫过去。主将和副将都倒下后，五万黄巾先愣住了。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.0,
