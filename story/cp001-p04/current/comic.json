        "aspect_ratio": "4:3",
        "crop_mode": "contain"
      },
      "text_block": {
        "title": "大兴山下照了面",
        "items": [
          {
            "id": "f2_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "大兴山下，两军第一次照了面。五百人像一把小刀，对面却是漫山的黄巾潮水。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.0,
        "y": 0.1653,
