      "text_block": {
        "title": "五百人先领了命",
        "items": [
          {
            "id": "f1_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "黄巾贼将程远志带五万人直奔涿郡。刘焉只得派邹靖领刘备三兄弟和五百乡勇去迎敌。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
