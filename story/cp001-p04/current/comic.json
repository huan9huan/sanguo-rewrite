        "aspect_ratio": "4:3",
        "crop_mode": "contain"
      },
      "text_block": {
        "title": "张飞先开了杀戒",
        "items": [
          {
            "id": "f3_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "副将邓茂先冲了出来。刘备只朝张飞轻轻一点头，丈八矛就先把人钉下了马。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.4461,
        "y": 0.1653,
        "w": 0.5539,
