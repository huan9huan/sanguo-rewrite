      "text_block": {
        "title": "袁绍献计",
        "items": [
          {
            "id": "f1_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "袁绍献计：召四方兵马进京，逼太后同意诛宦官。",
            "lang": "zh-CN"
          },
          {
            "id": "f1_t2",
            "kind": "caption",
            "speaker": "narrator",
            "text": "何进听了心动。他举不起自己的刀，却敢把外兵叫进洛阳。",
            "lang": "zh-CN"
          },
          {
            "id": "f1_t3",
            "kind": "caption",
            "speaker": "narrator",
            "text": "灵帝驾崩，何进拥立新帝。杀宦官的事被太后拦了三次——袁绍出了个主意。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.0,
        "y": 0.0,
        "w": 1.0,
        "h": 0.3359
      }
    },
    {
      "frame_id": "f2",
      "scene_id": "cp002_p05_s3",
      "image_slot": {
        "asset_key": "cp002-p05-page-01-f2",
        "aspect_ratio": "4:3",
        "crop_mode": "contain"
      },
      "text_block": {
        "title": "倒持干戈",
        "items": [
          {
            "id": "f2_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "陈琳看出了祸根：这是倒拿兵器，把刀柄递给别人。",
            "lang": "zh-CN"
          },
          {
            "id": "f2_t2",
            "kind": "caption",
            "speaker": "narrator",
            "text": "主簿陈琳说：将军手握皇威掌管兵权，要杀几个宦官如大火炉烧毛发。偏偏要召外兵，各怀异心——这是把刀柄递给人家。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.0,
        "y": 0.3359,
        "w": 0.5087,
        "h": 0.3315
      }
    },
    {
      "frame_id": "f3",
      "scene_id": "cp002_p05_s3",
      "image_slot": {
        "asset_key": "cp002-p05-page-01-f3",
        "aspect_ratio": "4:3",
        "crop_mode": "contain"
      },
      "text_block": {
        "title": "懦夫之见",
        "items": [
          {
            "id": "f3_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "何进没有听劝。他盖下印，把檄文发往各镇。",
            "lang": "zh-CN"
          },
          {
            "id": "f3_t2",
            "kind": "caption",
            "speaker": "narrator",
            "text": "何进看了檄文，盖了印，发往各镇。召四方兵马进京。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.5087,
        "y": 0.3359,
        "w": 0.4913,
        "h": 0.3315
      }
    },
    {
