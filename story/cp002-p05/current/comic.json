      "text_block": {
        "title": "懦夫之见",
        "items": [
          {
            "id": "f3_t1",
            "kind": "speech",
            "speaker": "he_jin",
            "text": "懦夫之见。",
            "lang": "zh-CN"
          },
          {
            "id": "f3_t2",
            "kind": "caption",
            "speaker": "narrator",
            "text": "何进看了檄文，盖了印，发往各镇。召四方兵马进京。",
            "lang": "zh-CN"
          }
        ]
      },
