      "text_block": {
        "title": "袁绍献计",
        "items": [
          {
            "id": "f1_t1",
            "kind": "speech",
            "speaker": "yuan_shao",
            "text": "可召四方英雄之士，带兵进京。到那时候事急了，太后不从也得从。",
            "lang": "zh-CN"
          },
          {
            "id": "f1_t2",
            "kind": "speech",
            "speaker": "he_jin",
            "text": "此计大妙！",
            "lang": "zh-CN"
          },
          {
            "id": "f1_t3",
            "kind": "caption",
            "speaker": "narrator",
            "text": "灵帝驾崩，何进拥立新帝。杀宦官的事被太后拦了三次——袁绍出了个主意。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.0,
        "y": 0.0,
        "w": 1.0,
        "h": 0.3359
      }
    },
    {
      "frame_id": "f2",
      "scene_id": "cp002_p05_s3",
      "image_slot": {
        "asset_key": "cp002-p05-page-01-f2",
        "aspect_ratio": "4:3",
        "crop_mode": "contain"
      },
      "text_block": {
        "title": "倒持干戈",
        "items": [
          {
            "id": "f2_t1",
            "kind": "speech",
            "speaker": "chen_lin",
            "text": "倒持干戈，授人以柄——事成不了，反要生乱！",
            "lang": "zh-CN"
          },
          {
            "id": "f2_t2",
            "kind": "caption",
            "speaker": "narrator",
            "text": "主簿陈琳说：将军手握皇威掌管兵权，要杀几个宦官如大火炉烧毛发。偏偏要召外兵，各怀异心——这是把刀柄递给人家。",
            "lang": "zh-CN"
          }
        ]
      },
      "panel_box": {
        "x": 0.0,
