      "text_block": {
        "title": "怒鞭督邮",
        "items": [
          {
            "id": "f3_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "张飞听见百姓哭诉，怒火再也压不住。",
            "lang": "zh-CN"
          },
          {
            "id": "f3_t2",
            "kind": "caption",
            "speaker": "narrator",
            "text": "张飞把他从馆驿拖出来，绑在马桩上，柳条打折了十几根。",
            "lang": "zh-CN"
          }
        ]
      },
