        "title": "假哭操控",
        "items": [
          {
            "id": "f3_t1",
            "kind": "caption",
            "speaker": "narrator",
            "text": "宦官们跪地假哭，把忠臣的直谏变成了自己的委屈。",
            "lang": "zh-CN"
          },
          {
            "id": "f3_t2",
            "kind": "caption",
            "speaker": "narrator",
            "text": "皇帝听信哭声，下令把忠臣推出去斩了。",
            "lang": "zh-CN"
          }
        ]
      },
