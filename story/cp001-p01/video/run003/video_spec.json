        "voice_id": "listener_zh",
        "rate": 1.05,
        "input_kind": "markup"
      }
    },
    {
      "segment_id": "s05",
      "speaker_id": "narrator",
      "text": "怪风吹进大殿，一条青蛇，落上龙椅。",
      "function": "image_hook",
      "delivery_note": "青蛇前稍慢，画面感强。",
