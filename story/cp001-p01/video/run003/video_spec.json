  "conversation_segments": [
    {
      "segment_id": "s01",
      "speaker_id": "narrator",
      "text": "汉朝四百年，到了灵帝手里，已经撑不住了。",
      "function": "hook",
      "delivery_note": "稳，但不要拖。",
