      "tts_hint": {
        "voice_id": "listener_zh",
        "rate": 1.08,
        "input_kind": "markup"
      }
    },
    {
      "segment_id": "s03",
      "speaker_id": "narrator",
      "text": "从宫里。太监掌权，真话被封住。",
