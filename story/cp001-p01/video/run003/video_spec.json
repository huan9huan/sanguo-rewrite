      "delivery_note": "有判断力，别讲成资料。",
      "tts_hint": {
        "voice_id": "narrator_zh",
        "rate": 1.0,
        "input_kind": "markup"
      }
    },
    {
      "segment_id": "s04",
      "speaker_id": "listener",
      "text": "难怪天下不安。",
