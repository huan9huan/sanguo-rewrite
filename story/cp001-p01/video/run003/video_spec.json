        "voice_id": "narrator_zh",
        "rate": 0.96,
        "input_kind": "markup"
      }
    },
    {
      "segment_id": "s06",
      "speaker_id": "listener",
      "text": "这是凶兆吧？",
      "function": "question",
      "delivery_note": "不是惊叫，是被带入。",
      "tts_hint": {
        "voice_id": "listener_zh",
        "rate": 1.05,
        "input_kind": "markup"
      }
    },
    {
      "segment_id": "s07",
      "speaker_id": "narrator",
      "text": "民间也起火。张角救病聚众，喊出：[pause] 苍天已死，黄天当立。",
