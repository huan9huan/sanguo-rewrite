      "delivery_note": "从宫廷转民间，节奏推进。",
      "tts_hint": {"voice_id": "narrator_zh", "rate": 1.02, "input_kind": "markup"}
    },
    {
      "segment_id": "s06",
      "speaker_id": "listener",
      "text": "他喊了什么？",
      "function": "question",
      "delivery_note": "为口号留位置。",
      "tts_hint": {"voice_id": "listener_zh", "rate": 1.06, "input_kind": "markup"}
    },
    {
      "segment_id": "s07",
      "speaker_id": "narrator",
      "text": "[pause] 苍天已死，黄天当立。",
      "function": "slogan",
      "delivery_note": "口号前留白，郑重但不喊。",
      "tts_hint": {"voice_id": "slogan_zh", "rate": 0.94, "input_kind": "markup"}
