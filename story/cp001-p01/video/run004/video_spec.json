      "delivery_note": "轻声代入，不夸张。",
      "tts_hint": {"voice_id": "listener_zh", "rate": 1.05, "input_kind": "markup"}
    },
    {
      "segment_id": "s05",
      "speaker_id": "narrator",
      "text": "宫里乱，民间也乱。张角救病聚众，黄巾越滚越大。",
