{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChapterSpec",
  "type": "object",
  "required": ["chapter_id", "source_title", "viewpoint", "goal", "passage_count"],
  "properties": {
    "chapter_id": {"type": "string"},
    "source_title": {"type": "string"},
    "adapted_title_cn": {"type": "string"},
    "viewpoint": {"type": "array", "items": {"type": "string"}},
    "audience": {"type": "string"},
    "goal": {"type": "string"},
    "passage_count": {"type": "integer", "minimum": 1},
    "global_arc": {"type": "string"},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "status": {"type": "string"}
  }
}
